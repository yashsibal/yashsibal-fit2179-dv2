{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "#FBF7EF",
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "labelColor": "#1F2937",
      "titleColor": "#111827",
      "gridColor": "#E5E7EB",
      "domainColor": "#CBD5E1",
      "tickColor": "#CBD5E1"
    },
    "legend": {
      "labelFont": "Inter, Arial, sans-serif",
      "titleFont": "Inter, Arial, sans-serif",
      "orient": "bottom",
      "labelLimit": 160
    },
    "title": {
      "font": "Inter, Arial, sans-serif",
      "fontSize": 16,
      "subtitleFont": "Inter, Arial, sans-serif",
      "subtitleFontSize": 12,
      "anchor": "start",
      "color": "#111827",
      "subtitleColor": "#4B5563"
    },
    "bar": {
      "cornerRadiusEnd": 4
    }
  },
  "title": {
    "text": "The final picture: sport and fitness sit on a participation spectrum",
    "subtitle": "Circle size shows adult participation rate; position is a derived storytelling classification."
  },
  "data": {
    "url": "data/sport_fitness_spectrum.csv"
  },
  "width": "container",
  "height": 230,
  "layer": [
    {
      "mark": {
        "type": "rule",
        "stroke": "#CBD5E1",
        "strokeWidth": 5
      },
      "encoding": {
        "x": {
          "datum": 1
        },
        "x2": {
          "datum": 10
        },
        "y": {
          "datum": 100
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "fontSize": 12,
        "fontWeight": "bold",
        "dy": -58
      },
      "encoding": {
        "x": {
          "datum": 1.2
        },
        "y": {
          "datum": 100
        },
        "text": {
          "value": "Traditional organised sport"
        },
        "color": {
          "value": "#2563EB"
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "fontSize": 12,
        "fontWeight": "bold",
        "dy": -58
      },
      "encoding": {
        "x": {
          "datum": 8.8
        },
        "y": {
          "datum": 100
        },
        "text": {
          "value": "Flexible lifestyle fitness"
        },
        "color": {
          "value": "#10B981"
        }
      }
    },
    {
      "mark": {
        "type": "circle",
        "opacity": 0.85,
        "stroke": "#FFFFFF",
        "strokeWidth": 1.2,
        "tooltip": true
      },
      "encoding": {
        "x": {
          "field": "spectrum_score",
          "type": "quantitative",
          "scale": {
            "domain": [
              0.7,
              10.3
            ]
          },
          "axis": null
        },
        "y": {
          "datum": 100,
          "type": "quantitative",
          "axis": null
        },
        "size": {
          "field": "participation_rate_pct",
          "type": "quantitative",
          "title": "Participation rate (%)",
          "scale": {
            "range": [
              100,
              3600
            ]
          }
        },
        "color": {
          "field": "side",
          "type": "nominal",
          "title": null,
          "scale": {
            "domain": [
              "Traditional sport",
              "Flexible lifestyle fitness"
            ],
            "range": [
              "#2563EB",
              "#10B981"
            ]
          }
        },
        "tooltip": [
          {
            "field": "activity",
            "title": "Activity"
          },
          {
            "field": "side",
            "title": "Side"
          },
          {
            "field": "participation_rate_pct",
            "title": "Participation rate (%)",
            "format": ".1f"
          },
          {
            "field": "estimated_participants",
            "title": "Estimated adult participants",
            "format": ","
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "dy": 55,
        "fontSize": 10,
        "baseline": "top"
      },
      "encoding": {
        "x": {
          "field": "spectrum_score",
          "type": "quantitative",
          "scale": {
            "domain": [
              0.7,
              10.3
            ]
          },
          "axis": null
        },
        "y": {
          "datum": 100,
          "type": "quantitative",
          "axis": null
        },
        "text": {
          "field": "activity"
        },
        "color": {
          "value": "#111827"
        }
      }
    }
  ]
}